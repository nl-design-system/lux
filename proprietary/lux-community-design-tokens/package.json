{
  "version": "2.0.0",
  "author": "Logius",
  "description": "Community Design Tokens for LUX, the Design System for Logius, based on the NL Design System architecture",
  "license": "SEE LICENSE IN LICENSE.md",
  "name": "@lux-design-system/lux-community-design-tokens",
  "keywords": [
    "nl-design-system",
    "lux-design-system"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "dist/"
  ],
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:nl-design-system/lux.git",
    "directory": "proprietary/lux-community-design-tokens"
  },
  "homepage": "https://nl-design-system.github.io/lux/",
  "bugs": "https://github.com/nl-design-system/lux/issues",
  "scripts": {
    "clean": "rimraf dist/",
    "lint": "jsonlint -q -F src/**/*.json",
    "merge-token-sets": "node ./merge-token-sets.mjs",
    "prebuild": "npm run clean && npm run merge-token-sets",
    "build": "node ./build.mjs",
    "watch": "chokidar --follow-symlinks --initial --command 'npm run build' 'src/**/*.json'",
    "test": "vitest",
    "prepack": "npm-run-all build lint"
  },
  "devDependencies": {
    "@prantlf/jsonlint": "14.0.3",
    "@tokens-studio/sd-transforms": "2.0.1",
    "chokidar-cli": "3.0.0",
    "cpy-cli": "5.0.0",
    "mkdirp": "3.0.1",
    "npm-run-all": "4.1.5",
    "rimraf": "6.0.1",
    "style-dictionary": "5.0.4",
    "vitest": "3.2.4"
  },
  "dependencies": {
    "@rijkshuisstijl-community/design-tokens": "11.1.0",
    "cross-env": "7.0.3"
  }
}
