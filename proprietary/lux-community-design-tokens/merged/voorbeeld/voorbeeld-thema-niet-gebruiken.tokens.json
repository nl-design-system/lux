{
  "brand/text": {
    "rhc": {
      "text": {
        "font-weight": {
          "extra-bold": {
            "$type": "fontWeights",
            "$value": "800"
          },
          "bold": {
            "$type": "fontWeights",
            "$value": "700"
          },
          "semi-bold": {
            "$type": "fontWeights",
            "$value": "600"
          },
          "regular": {
            "$type": "fontWeights",
            "$value": "400"
          },
          "light": {
            "$type": "fontWeights",
            "$value": "300"
          },
          "thin": {
            "$type": "fontWeights",
            "$value": "200"
          }
        },
        "font-family": {
          "sans": {
            "$type": "fontFamilies",
            "$value": "'Fira Sans', Arial, Verdana, sans-serif"
          },
          "serif": {
            "$type": "fontFamilies",
            "$value": "RijksoverheidSerifWeb, 'Times New Roman', serif"
          }
        },
        "font-size": {
          "max": {
            "md": {
              "$type": "fontSizes",
              "$value": "1.25rem"
            },
            "lg": {
              "$type": "fontSizes",
              "$value": "1.5rem"
            },
            "xl": {
              "$type": "fontSizes",
              "$value": "1.875rem"
            },
            "2xl": {
              "$type": "fontSizes",
              "$value": "2.5rem"
            },
            "3xl": {
              "$type": "fontSizes",
              "$value": "3.125rem"
            }
          },
          "min": {
            "md": {
              "$type": "fontSizes",
              "$value": "1rem"
            },
            "lg": {
              "$type": "fontSizes",
              "$value": "1.2rem"
            },
            "xl": {
              "$type": "fontSizes",
              "$value": "1.5rem"
            },
            "2xl": {
              "$type": "fontSizes",
              "$value": "2rem"
            },
            "3xl": {
              "$type": "fontSizes",
              "$value": "2.5rem"
            }
          }
        }
      }
    }
  },
  "common/text": {
    "rhc": {
      "text": {
        "font-size": {
          "md": {
            "$type": "fontSizes",
            "$value": "{rhc.text.font-size.max.md}"
          },
          "lg": {
            "$type": "fontSizes",
            "$value": "{rhc.text.font-size.max.lg}"
          },
          "xl": {
            "$type": "fontSizes",
            "$value": "{rhc.text.font-size.max.xl}"
          },
          "2xl": {
            "$type": "fontSizes",
            "$value": "{rhc.text.font-size.max.2xl}"
          },
          "3xl": {
            "$type": "fontSizes",
            "$value": "{rhc.text.font-size.max.3xl}"
          }
        },
        "font-family": {
          "default": {
            "$type": "fontFamilies",
            "$value": "{rhc.text.font-family.sans}"
          }
        },
        "line-height": {
          "sm": {
            "$type": "lineHeights",
            "$value": "125%"
          },
          "md": {
            "$type": "lineHeights",
            "$value": "150%"
          }
        },
        "font-weight": {
          "default": {
            "$type": "fontWeights",
            "$value": "{rhc.text.font-weight.regular}"
          },
          "strong": {
            "$type": "fontWeights",
            "$value": "{rhc.text.font-weight.bold}"
          }
        }
      }
    }
  },
  "overrides/ridiculous-font-size": {
    "rhc": {
      "text": {
        "font-size": {
          "md": {
            "$type": "fontSizes",
            "$value": "53.1px"
          }
        }
      }
    }
  }
}