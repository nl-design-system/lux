{
  "version": "0.0.1",
  "author": "Community for NL Design System",
  "description": "Community react component library for LUX, the Design System for Logius, based on the NL Design System architecture",
  "license": "EUPL-1.2",
  "name": "@lux-design-system/lux-community-components-react",
  "keywords": [
    "nl-design-system",
    "lux-design-system"
  ],
  "private": false,
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git+ssh",
    "url": "git@github.com:nl-design-system/lux.git",
    "directory": "packages/lux-community-components-react"
  },
  "scripts": {
    "prebuild": "npm run clean",
    "prepack": "npm run build",
    "build": "vite build",
    "clean": "rimraf dist/ pages/",
    "lint": "npm-run-all lint:*",
    "lint:src": "tsc --project ./tsconfig.json --noEmit",
    "lint:test": "tsc --project ./tsconfig.test.json --noEmit",
    "test": "vitest run --coverage --reporter verbose",
    "test-watch": "vitest --coverage --watch",
    "watch:components": "vite build --watch"
  },
  "main": "./dist/index.umd.js",
  "module": "./dist/index.mjs",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.mjs",
      "require": "./dist/index.umd.cjs"
    }
  },
  "files": [
    "dist/"
  ],
  "dependencies": {
    "clsx": "2.1.1",
    "date-fns": "3.6.0",
    "lodash.chunk": "4.2.0"
  },
  "devDependencies": {
    "@babel/core": "7.29.0",
    "@babel/plugin-transform-runtime": "7.29.0",
    "@babel/preset-env": "7.25.3",
    "@babel/preset-react": "7.28.5",
    "@babel/preset-typescript": "7.28.5",
    "@babel/runtime": "7.25.0",
    "@lux-design-system/components-css": "workspace:*",
    "@prantlf/jsonlint": "14.0.3",
    "@testing-library/dom": "10.4.1",
    "@testing-library/jest-dom": "6.9.1",
    "@testing-library/react": "16.3.2",
    "@testing-library/user-event": "14.6.1",
    "@types/jest": "29.5.12",
    "@types/lodash.chunk": "4.2.9",
    "@types/react": "18.3.3",
    "@vitejs/plugin-react": "4.7.0",
    "@vitest/coverage-v8": "3.2.4",
    "cross-env": "7.0.3",
    "mkdirp": "3.0.1",
    "next": "14.2.33",
    "npm-run-all": "4.1.5",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "rimraf": "6.1.3",
    "rollup": "4.59.0",
    "sass": "1.98.0",
    "tslib": "2.8.1",
    "typescript": "5.9.3",
    "vite": "6.3.5",
    "vite-plugin-css-injected-by-js": "3.5.2",
    "vite-plugin-dts": "4.5.4",
    "vite-plugin-runtime-config": "1.0.2",
    "vitest": "3.2.4"
  },
  "peerDependencies": {
    "react": "18",
    "react-dom": "18"
  }
}
